{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "astro",
    "main": "@astrojs/cloudflare/entrypoints/server",
    "compatibility_date": "2025-04-15",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "assets": {
        "binding": "ASSETS",
        "directory": "./dist/client"
    },
    "observability": {
        "enabled": true
    }
}
