# Webflow Data API credentials.
# Copy to .env and fill in your token: cp .env.example .env

# Required: Webflow site API token with CMS read access.
# Create one at: Site settings → Apps & integrations → API access.
WEBFLOW_API_TOKEN=

# How long (seconds) runtime-fetched data is cached before refreshing from
# Webflow. No rebuild/redeploy needed to pick up CMS changes. 0 = fetch live on
# every request (slower, may hit rate limits). Default: 300 (5 minutes).
# SEARCH_INDEX_TTL_SECONDS=300

# Optional overrides. Defaults target the "Woodland Properties" site.
# WEBFLOW_SITE_ID=6a3ee562ea51d6c9ddc156c7
# WEBFLOW_AGENTS_COLLECTION_ID=6a3eeb88509425ae62309159
# WEBFLOW_AREAS_COLLECTION_ID=6a3ee7398f36f58b907d2df1
# WEBFLOW_SPECIALTIES_COLLECTION_ID=6a3ee77638f548e2e9600bb7
