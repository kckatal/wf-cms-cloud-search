# Webflow Data API credentials.
# Copy to .env and fill in your token: cp .env.example .env

# Required: Webflow site API token.
# Scopes needed for this app:
#   cms:read          — agent search index
#   cms:write         — profile editing (text fields, areas, specialties)
#   assets:write      — profile photo uploads
# Create at: Site settings → Apps & integrations → API access → Generate API token.
# You must select scopes when generating; existing tokens cannot be upgraded — mint a new one.
# After rotating the token, update .env, .dev.vars, and Webflow Cloud env vars, then restart dev.
WEBFLOW_API_TOKEN=

# How long (seconds) runtime-fetched data is cached before refreshing from
# Webflow. No rebuild/redeploy needed to pick up CMS changes. 0 = fetch live on
# every request (slower, may hit rate limits). Default: 300 (5 minutes).
# SEARCH_INDEX_TTL_SECONDS=300

# Public Webflow site origin for agent profile preview links (not the Cloud mount path).
# PUBLIC_SITE_URL=https://anderson-group-stage.webflow.io

# Optional overrides. Defaults target the "Woodland Properties" site.
# WEBFLOW_SITE_ID=6a3ee562ea51d6c9ddc156c7
# WEBFLOW_AGENTS_COLLECTION_ID=6a3eeb88509425ae62309159
# WEBFLOW_AREAS_COLLECTION_ID=6a3ee7398f36f58b907d2df1
# WEBFLOW_SPECIALTIES_COLLECTION_ID=6a3ee77638f548e2e9600bb7

# --- Auth0 (agent portal, Phase 1) ---
# Webflow Cloud: set these in Site settings → Webflow Cloud → Environment Variables.
# They are runtime-only on Cloudflare Workers (read via `cloudflare:workers`).
# Local dev: `.env` works with `npm run dev`; use `.dev.vars` for `npm run preview`.
# Create a Regular Web Application at auth0.com and register callback URLs.
# Local dev uses the same mount path placeholder as astro.config (CLOUD_MOUNT_PATH):
#   http://localhost:4321/CLOUD_MOUNT_PATH/auth/callback
# Production (replace <mount> with your Webflow Cloud mount path):
#   https://<staging>.webflow.io/<mount>/auth/callback
#   https://<production-domain>/<mount>/auth/callback
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_CALLBACK_URL=http://localhost:4321/CLOUD_MOUNT_PATH/auth/callback
# Optional: must match Auth0 Allowed Logout URLs exactly on staging/production.
# If omitted, derived from AUTH0_CALLBACK_URL by swapping /auth/callback → /login.
# AUTH0_LOGOUT_RETURN_URL=https://anderson-group-stage.webflow.io/<mount>/login
# Optional: namespace used in Auth0 Action custom claims (must match Action code).
# AUTH0_CLAIMS_NAMESPACE=https://anderson-group-stage.webflow.io

# Demo password used by `npm run auth0:import` when generating auth0-import.json.
# AUTH0_DEFAULT_PASSWORD=12345qwerty!

# --- Admin change log (Phase 4) ---
# Profile edits are stored in Cloudflare KV (binding CHANGELOG_KV in wrangler.json).
# Local `astro dev` uses an in-memory fallback; `npm run preview` uses wrangler KV.
# On Webflow Cloud, create a KV namespace and set its id in wrangler.json before deploy.
