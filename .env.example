# Webflow Data API credentials.
# Copy to .env and fill in your token: cp .env.example .env

# Required: Webflow site API token with CMS read access.
# Create one at: Site settings → Apps & integrations → API access.
WEBFLOW_API_TOKEN=

# How long (seconds) runtime-fetched data is cached before refreshing from
# Webflow. No rebuild/redeploy needed to pick up CMS changes. 0 = fetch live on
# every request (slower, may hit rate limits). Default: 300 (5 minutes).
# SEARCH_INDEX_TTL_SECONDS=300

# Optional overrides. Defaults target the "Woodland Properties" site.
# WEBFLOW_SITE_ID=6a3ee562ea51d6c9ddc156c7
# WEBFLOW_AGENTS_COLLECTION_ID=6a3eeb88509425ae62309159
# WEBFLOW_AREAS_COLLECTION_ID=6a3ee7398f36f58b907d2df1
# WEBFLOW_SPECIALTIES_COLLECTION_ID=6a3ee77638f548e2e9600bb7

# --- Auth0 (agent portal, Phase 1) ---
# Webflow Cloud: set these in Site settings → Webflow Cloud → Environment Variables.
# They are runtime-only on Cloudflare Workers (accessed via locals.runtime.env).
# Local dev: .env works with `npm run dev`; use dev.vars for `npm run preview`.
# Create a Regular Web Application at auth0.com and register callback URLs.
# Local dev uses the same mount path placeholder as astro.config (CLOUD_MOUNT_PATH):
#   http://localhost:4321/CLOUD_MOUNT_PATH/auth/callback
# Production (replace <mount> with your Webflow Cloud mount path):
#   https://<staging>.webflow.io/<mount>/auth/callback
#   https://<production-domain>/<mount>/auth/callback
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_CALLBACK_URL=http://localhost:4321/CLOUD_MOUNT_PATH/auth/callback
