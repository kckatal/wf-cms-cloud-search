---
import SiteNav from "../components/SiteNav";
import SiteFooter from "../components/SiteFooter";
import { appPath } from "../lib/app-path";
import {
  getSessionFromRequest,
  isAgent,
  isAuthConfigured,
} from "../lib/auth";
import { agentToProfileView } from "../lib/profile/fields";
import { formatHeadshotMaxSize, HEADSHOT_ACCEPT, HEADSHOT_MAX_BYTES } from "../lib/profile/headshot";
import { agentPublicProfileUrl } from "../lib/site-url";
import { fetchAgentById, fetchTaxonomyOptions } from "../lib/webflow/agents";
import "webflow/css/global.css";
import "../styles/site.css";

export const prerender = false;

const loginUrl = appPath("login");
const profileApiUrl = appPath("api/agent/profile");
const headshotMaxLabel = formatHeadshotMaxSize();

const authReady = isAuthConfigured();
const session = authReady
  ? await getSessionFromRequest(Astro.request.headers.get("cookie"))
  : null;

if (!session) {
  return Astro.redirect(loginUrl);
}

if (!isAgent(session) || !session.agentId) {
  return Astro.redirect(`${loginUrl}?error=not_linked`);
}

const agent = await fetchAgentById(session.agentId);
const options = await fetchTaxonomyOptions();

if (!agent) {
  return Astro.redirect(`${loginUrl}?error=agent_not_found`);
}

const profile = agentToProfileView(agent);
const previewUrl = agentPublicProfileUrl(profile.slug);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Edit profile — {profile.name}</title>
    <style>
      .profile {
        max-width: 40rem;
        margin: 3rem auto 4rem;
        padding: 0 1.5rem;
      }
      .profile__card {
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        padding: 2rem;
        background: #fff;
      }
      .profile__title {
        margin: 0 0 0.25rem;
        font-size: 1.5rem;
      }
      .profile__sub {
        margin: 0 0 1.5rem;
        color: #6b7280;
        font-size: 0.875rem;
      }
      .profile__sub a {
        color: #2b6cb0;
        font-weight: 600;
      }
      .profile__grid {
        display: grid;
        gap: 1rem;
      }
      .field__label {
        display: block;
        margin-bottom: 0.375rem;
        font-size: 0.875rem;
        font-weight: 600;
      }
      .field input:not([type="checkbox"]),
      .field textarea {
        width: 100%;
        box-sizing: border-box;
        padding: 0.625rem 0.75rem;
        border: 1px solid #d1d5db;
        border-radius: 0.5rem;
        font: inherit;
      }
      .field textarea {
        min-height: 7rem;
        resize: vertical;
      }
      .check-search {
        width: 100%;
        box-sizing: border-box;
        margin-bottom: 0.5rem;
        padding: 0.5rem 0.75rem;
        border: 1px solid #d1d5db;
        border-radius: 0.5rem;
        font: inherit;
        background: #fff;
      }
      .check-list {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
        max-height: 14rem;
        overflow-y: auto;
        padding: 0.375rem;
        border: 1px solid #d1d5db;
        border-radius: 0.5rem;
        background: #fafafa;
      }
      .check-item {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0.375rem 0.5rem;
        border-radius: 0.375rem;
        cursor: pointer;
        font-size: 0.875rem;
        font-weight: 400;
        line-height: 1.3;
      }
      .check-item:hover {
        background: #f3f4f6;
      }
      .check-item input[type="checkbox"] {
        width: 1rem;
        height: 1rem;
        min-width: 1rem;
        flex-shrink: 0;
        margin: 0;
        accent-color: #111827;
      }
      .check-item__text {
        flex: 1;
        min-width: 0;
      }
      .check-item.is-hidden {
        display: none;
      }
      .check-list__empty {
        padding: 0.75rem;
        color: #6b7280;
        font-size: 0.875rem;
        text-align: center;
      }
      .check-list__empty.is-hidden {
        display: none;
      }
      .profile__actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.625rem 1.25rem;
        border-radius: 0.5rem;
        font-weight: 600;
        text-decoration: none;
        border: none;
        cursor: pointer;
        font: inherit;
      }
      .btn--primary {
        background: #111827;
        color: #fff;
      }
      .btn--secondary {
        background: #f3f4f6;
        color: #111827;
      }
      .status {
        margin-top: 1rem;
        font-size: 0.875rem;
      }
      .status--error { color: #991b1b; }
      .status--success { color: #166534; }
      .headshot {
        display: flex;
        gap: 1.25rem;
        align-items: flex-start;
        flex-wrap: wrap;
      }
      .headshot__preview {
        width: 6.5rem;
        height: 6.5rem;
        border-radius: 9999px;
        object-fit: cover;
        border: 1px solid #e5e7eb;
        background: #f3f4f6;
      }
      .headshot__preview--empty {
        background: linear-gradient(135deg, #e5e7eb 0%, #f9fafb 100%);
      }
      .headshot__controls {
        flex: 1;
        min-width: 12rem;
      }
      .headshot__hint {
        margin: 0.375rem 0 0;
        color: #6b7280;
        font-size: 0.8125rem;
        line-height: 1.4;
      }
      .headshot__input {
        font: inherit;
        font-size: 0.875rem;
      }
    </style>
  </head>
  <body>
    <SiteNav client:load />
    <main class="profile">
      <div class="profile__card">
        <h1 class="profile__title">Edit your profile</h1>
        <p class="profile__sub">
          {profile.name} · changes publish to the live site ·{" "}
          <a href={previewUrl} target="_blank" rel="noopener noreferrer">
            Preview public profile ↗
          </a>
        </p>

        <form class="profile__grid" id="profile-form">
          <div class="field">
            <label class="field__label" for="headshot">Profile photo</label>
            <div class="headshot">
              {
                profile.headshotUrl ? (
                  <img
                    class="headshot__preview"
                    id="headshot-preview"
                    src={profile.headshotUrl}
                    alt={profile.headshotAlt ?? profile.name}
                    width="104"
                    height="104"
                  />
                ) : (
                  <div class="headshot__preview headshot__preview--empty" id="headshot-preview" aria-hidden="true" />
                )
              }
              <div class="headshot__controls">
                <input
                  class="headshot__input"
                  id="headshot"
                  name="headshot"
                  type="file"
                  accept={HEADSHOT_ACCEPT}
                />
                <p class="headshot__hint">
                  JPEG, PNG, or WebP · max {headshotMaxLabel}. Uploads when you save.
                </p>
              </div>
            </div>
          </div>
          <div class="field">
            <label for="phone">Phone</label>
            <input id="phone" name="phone" type="tel" value={profile.phone ?? ""} />
          </div>
          <div class="field">
            <label for="phoneLabel">Phone label</label>
            <input id="phoneLabel" name="phoneLabel" type="text" value={profile.phoneLabel ?? ""} />
          </div>
          <div class="field">
            <label for="brokerageName">Brokerage</label>
            <input id="brokerageName" name="brokerageName" type="text" value={profile.brokerageName ?? ""} />
          </div>
          <div class="field">
            <label for="licenseNumber">License number</label>
            <input id="licenseNumber" name="licenseNumber" type="text" value={profile.licenseNumber ?? ""} />
          </div>
          <div class="field">
            <label for="streetAddress">Street address</label>
            <input id="streetAddress" name="streetAddress" type="text" value={profile.streetAddress ?? ""} />
          </div>
          <div class="field">
            <label for="cityStateZip">City, state, zip</label>
            <input id="cityStateZip" name="cityStateZip" type="text" value={profile.cityStateZip ?? ""} />
          </div>
          <div class="field">
            <label for="bio">Bio</label>
            <textarea id="bio" name="bio">{profile.bio ?? ""}</textarea>
          </div>
          <div class="field">
            <label for="websiteName">Website name</label>
            <input id="websiteName" name="websiteName" type="text" value={profile.websiteName ?? ""} />
          </div>
          <div class="field">
            <label for="websiteUrl">Website URL</label>
            <input id="websiteUrl" name="websiteUrl" type="url" value={profile.websiteUrl ?? ""} />
          </div>
          <div class="field">
            <label for="companyName">Company name</label>
            <input id="companyName" name="companyName" type="text" value={profile.companyName ?? ""} />
          </div>
          <div class="field">
            <label for="companyUrl">Company URL</label>
            <input id="companyUrl" name="companyUrl" type="url" value={profile.companyUrl ?? ""} />
          </div>
          <div class="field">
            <label class="field__label" for="area-search">Areas served</label>
            <input
              id="area-search"
              class="check-search"
              type="search"
              placeholder="Search areas…"
              autocomplete="off"
              data-target="area-list"
            />
            <div class="check-list" id="area-list">
              {
                options.areas.map((area) => (
                  <label class="check-item" data-label={area.name.toLowerCase()}>
                    <input
                      type="checkbox"
                      name="areaIds"
                      value={area.id}
                      checked={profile.areaIds.includes(area.id)}
                    />
                    <span class="check-item__text">{area.name}</span>
                  </label>
                ))
              }
              <p class="check-list__empty is-hidden" data-empty-for="area-list">No areas match your search.</p>
            </div>
          </div>
          <div class="field">
            <label class="field__label" for="specialty-search">Specialties</label>
            <input
              id="specialty-search"
              class="check-search"
              type="search"
              placeholder="Search specialties…"
              autocomplete="off"
              data-target="specialty-list"
            />
            <div class="check-list" id="specialty-list">
              {
                options.specialties.map((specialty) => (
                  <label class="check-item" data-label={specialty.name.toLowerCase()}>
                    <input
                      type="checkbox"
                      name="specialtyIds"
                      value={specialty.id}
                      checked={profile.specialtyIds.includes(specialty.id)}
                    />
                    <span class="check-item__text">{specialty.name}</span>
                  </label>
                ))
              }
              <p class="check-list__empty is-hidden" data-empty-for="specialty-list">No specialties match your search.</p>
            </div>
          </div>

          <div class="profile__actions">
            <button class="btn btn--primary" type="submit">Save changes</button>
            <a class="btn btn--secondary" href={loginUrl}>Back to portal</a>
          </div>
        </form>

        <p class="status" id="status" hidden></p>
      </div>
    </main>
    <SiteFooter client:load />

    <script define:vars={{ profileApiUrl, headshotMaxBytes: HEADSHOT_MAX_BYTES }}>
      const form = document.getElementById("profile-form");
      const status = document.getElementById("status");
      const headshotInput = document.getElementById("headshot");
      const headshotPreview = document.getElementById("headshot-preview");
      let headshotPreviewUrl = null;

      function showStatus(message, type) {
        if (!status) return;
        status.hidden = false;
        status.textContent = message;
        status.className = `status status--${type}`;
      }

      function filterCheckList(input) {
        const listId = input.dataset.target;
        if (!listId) return;
        const list = document.getElementById(listId);
        if (!list) return;

        const query = input.value.trim().toLowerCase();
        const items = list.querySelectorAll(".check-item");
        let visible = 0;

        items.forEach((item) => {
          const label = item.dataset.label ?? "";
          const show = !query || label.includes(query);
          item.classList.toggle("is-hidden", !show);
          if (show) visible += 1;
        });

        const empty = list.querySelector(`[data-empty-for="${listId}"]`);
        if (empty) {
          empty.classList.toggle("is-hidden", visible > 0);
        }
      }

      document.querySelectorAll(".check-search").forEach((input) => {
        input.addEventListener("input", () => filterCheckList(input));
      });

      headshotInput?.addEventListener("change", () => {
        const file = headshotInput.files?.[0];
        if (!file) return;

        if (file.size > headshotMaxBytes) {
          showStatus(`Photo must be ${Math.round(headshotMaxBytes / 1024)} KB or smaller.`, "error");
          headshotInput.value = "";
          return;
        }

        if (headshotPreviewUrl) URL.revokeObjectURL(headshotPreviewUrl);
        headshotPreviewUrl = URL.createObjectURL(file);
        if (headshotPreview instanceof HTMLImageElement) {
          headshotPreview.src = headshotPreviewUrl;
        } else if (headshotPreview instanceof HTMLElement) {
          const img = document.createElement("img");
          img.id = "headshot-preview";
          img.className = "headshot__preview";
          img.alt = "Selected profile photo preview";
          img.width = 104;
          img.height = 104;
          img.src = headshotPreviewUrl;
          headshotPreview.replaceWith(img);
        }
        status.hidden = true;
      });

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!form) return;

        const headshotFile = headshotInput?.files?.[0];
        if (headshotFile && headshotFile.size > headshotMaxBytes) {
          showStatus(`Photo must be ${Math.round(headshotMaxBytes / 1024)} KB or smaller.`, "error");
          return;
        }

        const submitData = new FormData(form);
        submitData.delete("areaIds");
        submitData.delete("specialtyIds");
        for (const el of form.querySelectorAll('input[name="areaIds"]:checked')) {
          submitData.append("areaIds", el.value);
        }
        for (const el of form.querySelectorAll('input[name="specialtyIds"]:checked')) {
          submitData.append("specialtyIds", el.value);
        }
        if (headshotFile) {
          submitData.set("headshot", headshotFile);
        }

        showStatus("Saving…", "success");

        try {
          const res = await fetch(profileApiUrl, {
            method: "PATCH",
            credentials: "include",
            body: submitData,
          });
          const json = await res.json().catch(() => ({}));
          if (!res.ok) {
            showStatus(json.message ?? json.error ?? "Save failed.", "error");
            return;
          }

          if (headshotPreview instanceof HTMLImageElement && json.profile?.headshotUrl) {
            headshotPreview.src = json.profile.headshotUrl;
          }
          if (headshotInput) headshotInput.value = "";
          showStatus("Profile saved and published.", "success");
        } catch {
          showStatus("Network error. Please try again.", "error");
        }
      });
    </script>
  </body>
</html>
